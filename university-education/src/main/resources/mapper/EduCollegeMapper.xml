<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.edu.mapper.EduCollegeMapper">
    
    <resultMap id="BaseResultMap" type="com.edu.entity.EduCollege">
        <id column="id" property="id"/>
        <result column="college_code" property="collegeCode"/>
        <result column="college_name" property="collegeName"/>
        <result column="description" property="description"/>
        <result column="sort" property="sort"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>
    
    <sql id="Base_Column_List">
        id, college_code, college_name, description, sort, status, create_time, update_time
    </sql>
    
    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM edu_college WHERE id = #{id}
    </select>
    
    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM edu_college
        <where>
            <if test="collegeCode != null and collegeCode != ''">
                AND college_code LIKE CONCAT('%', #{collegeCode}, '%')
            </if>
            <if test="collegeName != null and collegeName != ''">
                AND college_name LIKE CONCAT('%', #{collegeName}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        ORDER BY sort ASC, id ASC
    </select>
    
    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM edu_college WHERE status = 1 ORDER BY sort ASC
    </select>
    
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO edu_college (college_code, college_name, description, sort, status)
        VALUES (#{collegeCode}, #{collegeName}, #{description}, #{sort}, #{status})
    </insert>
    
    <update id="update">
        UPDATE edu_college
        <set>
            <if test="collegeCode != null">college_code = #{collegeCode},</if>
            <if test="collegeName != null">college_name = #{collegeName},</if>
            <if test="description != null">description = #{description},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>
    
    <delete id="deleteById">
        DELETE FROM edu_college WHERE id = #{id}
    </delete>
    
    <delete id="deleteByIds">
        DELETE FROM edu_college WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
    <select id="checkCodeExists" resultType="int">
        SELECT COUNT(1) FROM edu_college WHERE college_code = #{collegeCode}
        <if test="excludeId != null">AND id != #{excludeId}</if>
    </select>
    
    <select id="checkNameExists" resultType="int">
        SELECT COUNT(1) FROM edu_college WHERE college_name = #{collegeName}
        <if test="excludeId != null">AND id != #{excludeId}</if>
    </select>
    
    <select id="count" resultType="int">
        SELECT COUNT(1) FROM edu_college
    </select>
</mapper>
