<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.edu.mapper.EduEvaluationAnswerMapper">

    <resultMap id="BaseResultMap" type="com.edu.entity.EduEvaluationAnswer">
        <id column="id" property="id"/>
        <result column="evaluation_id" property="evaluationId"/>
        <result column="question_id" property="questionId"/>
        <result column="score" property="score"/>
        <result column="answer_text" property="answerText"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectByEvaluationId" resultMap="BaseResultMap">
        SELECT * FROM edu_evaluation_answer
        WHERE evaluation_id = #{evaluationId}
        ORDER BY question_id ASC
    </select>

    <insert id="batchInsert">
        INSERT INTO edu_evaluation_answer (evaluation_id, question_id, score, answer_text)
        VALUES
        <foreach collection="list" item="a" separator=",">
            (#{a.evaluationId}, #{a.questionId}, #{a.score}, #{a.answerText})
        </foreach>
    </insert>

</mapper>
