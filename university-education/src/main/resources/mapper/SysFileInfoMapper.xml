<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.edu.mapper.SysFileInfoMapper">

    <resultMap id="BaseResultMap" type="com.edu.entity.SysFileInfo">
        <id column="id" property="id"/>
        <result column="file_name" property="fileName"/>
        <result column="file_path" property="filePath"/>
        <result column="file_size" property="fileSize"/>
        <result column="file_type" property="fileType"/>
        <result column="file_ext" property="fileExt"/>
        <result column="uploader_id" property="uploaderId"/>
        <result column="uploader_name" property="uploaderName"/>
        <result column="upload_time" property="uploadTime"/>
    </resultMap>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM sys_file_info WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_file_info (
            file_name, file_path, file_size, file_type,
            file_ext, uploader_id, uploader_name
        )
        VALUES (
            #{fileName}, #{filePath}, #{fileSize}, #{fileType},
            #{fileExt}, #{uploaderId}, #{uploaderName}
        )
    </insert>

    <delete id="deleteById">
        DELETE FROM sys_file_info WHERE id = #{id}
    </delete>

</mapper>
