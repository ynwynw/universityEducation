<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.edu.mapper.EduMajorMapper">
    
    <resultMap id="BaseResultMap" type="com.edu.entity.EduMajor">
        <id column="id" property="id"/>
        <result column="major_code" property="majorCode"/>
        <result column="major_name" property="majorName"/>
        <result column="college_id" property="collegeId"/>
        <result column="duration" property="duration"/>
        <result column="degree" property="degree"/>
        <result column="description" property="description"/>
        <result column="sort" property="sort"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="college_name" property="collegeName"/>
    </resultMap>
    
    <select id="selectById" resultMap="BaseResultMap">
        SELECT 
            m.*,
            c.college_name
        FROM edu_major m
        LEFT JOIN edu_college c ON m.college_id = c.id
        WHERE m.id = #{id}
    </select>
    
    <select id="selectList" resultMap="BaseResultMap">
        SELECT 
            m.*,
            c.college_name
        FROM edu_major m
        LEFT JOIN edu_college c ON m.college_id = c.id
        <where>
            <if test="majorCode != null and majorCode != ''">
                AND m.major_code LIKE CONCAT('%', #{majorCode}, '%')
            </if>
            <if test="majorName != null and majorName != ''">
                AND m.major_name LIKE CONCAT('%', #{majorName}, '%')
            </if>
            <if test="collegeId != null">
                AND m.college_id = #{collegeId}
            </if>
            <if test="status != null">
                AND m.status = #{status}
            </if>
        </where>
        ORDER BY m.sort ASC, m.id ASC
    </select>
    
    <select id="selectByCollegeId" resultMap="BaseResultMap">
        SELECT * 
        FROM edu_major 
        WHERE college_id = #{collegeId} AND status = 1
        ORDER BY sort ASC
    </select>
    
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO edu_major (
            major_code,
            major_name,
            college_id,
            duration,
            degree,
            description,
            sort,
            status
        ) VALUES (
            #{majorCode},
            #{majorName},
            #{collegeId},
            #{duration},
            #{degree},
            #{description},
            #{sort},
            #{status}
        )
    </insert>
    
    <update id="update">
        UPDATE edu_major
        <set>
            <if test="majorCode != null">
                major_code = #{majorCode},
            </if>
            <if test="majorName != null">
                major_name = #{majorName},
            </if>
            <if test="collegeId != null">
                college_id = #{collegeId},
            </if>
            <if test="duration != null">
                duration = #{duration},
            </if>
            <if test="degree != null">
                degree = #{degree},
            </if>
            <if test="description != null">
                description = #{description},
            </if>
            <if test="sort != null">
                sort = #{sort},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
        </set>
        WHERE id = #{id}
    </update>
    
    <delete id="deleteById">
        DELETE FROM edu_major 
        WHERE id = #{id}
    </delete>
    
    <delete id="deleteByIds">
        DELETE FROM edu_major 
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
    <select id="checkCodeExists" resultType="int">
        SELECT COUNT(1) 
        FROM edu_major 
        WHERE major_code = #{majorCode}
        <if test="excludeId != null">
            AND id != #{excludeId}
        </if>
    </select>
    
    <select id="countByCollegeId" resultType="int">
        SELECT COUNT(1) 
        FROM edu_major 
        WHERE college_id = #{collegeId}
    </select>
    
    <select id="selectByMajorCode" resultMap="BaseResultMap">
        SELECT * 
        FROM edu_major 
        WHERE major_code = #{majorCode} 
        LIMIT 1
    </select>
    
</mapper>
