<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.edu.mapper.EduQuestionMapper">

    <resultMap id="BaseResultMap" type="com.edu.entity.EduQuestion">
        <id column="id" property="id"/>
        <result column="questionnaire_id" property="questionnaireId"/>
        <result column="question_content" property="questionContent"/>
        <result column="question_type" property="questionType"/>
        <result column="max_score" property="maxScore"/>
        <result column="weight" property="weight"/>
        <result column="sort" property="sort"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectByQuestionnaireId" resultMap="BaseResultMap">
        SELECT * FROM edu_question
        WHERE questionnaire_id = #{questionnaireId}
        ORDER BY sort ASC
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM edu_question WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO edu_question (questionnaire_id, question_content, question_type, max_score, weight, sort)
        VALUES (#{questionnaireId}, #{questionContent}, #{questionType}, #{maxScore}, #{weight}, #{sort})
    </insert>

    <update id="update">
        UPDATE edu_question
        <set>
            <if test="questionContent != null">question_content = #{questionContent},</if>
            <if test="questionType != null">question_type = #{questionType},</if>
            <if test="maxScore != null">max_score = #{maxScore},</if>
            <if test="weight != null">weight = #{weight},</if>
            <if test="sort != null">sort = #{sort},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM edu_question WHERE id = #{id}
    </delete>

    <delete id="deleteByQuestionnaireId">
        DELETE FROM edu_question WHERE questionnaire_id = #{questionnaireId}
    </delete>

</mapper>
